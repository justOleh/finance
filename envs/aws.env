# ------------------------------------------------------------------------------
# my-finance — AWS (prod) environment
# ------------------------------------------------------------------------------
# Populated from Terraform/Terragrunt outputs in terraform/environments/prod/.
# Real values (ALB DNS names, S3 bucket, ECR repo URIs, DynamoDB table) come
# from `terragrunt output` — the placeholders below are the shape only.
#
# Anything that is truly a secret (OPENAI_API_KEY, AWS credentials) should NOT
# be committed here — inject it from CI / AWS Secrets Manager / SSM at deploy
# time. Keep this file for non-secret configuration.
# ------------------------------------------------------------------------------

# --- Meta --------------------------------------------------------------------
PROJECT=
ENV_NAME=
IMAGE_TAG=

# --- AWS account / region ----------------------------------------------------
AWS_REGION=
AWS_ACCOUNT_ID=
AWS_PROFILE=

# --- Public URLs -------------------------------------------------------------
# Backend sits behind the PUBLIC ALB; receipt parser behind the INTERNAL ALB.
# Frontend is a static bundle served from S3 (optionally via CloudFront).
BACKEND_URL=
FRONTEND_URL=

# --- Backend (FastAPI on ECS Fargate) ----------------------------------------
# DynamoDB replaces the local SQLite DB — the backend service will read these
# vars (see terraform/modules/ecs-service task-definition env block).
DATABASE_URL=
DYNAMODB_TABLE=
DYNAMODB_REGION=

# Receipt parser is only reachable via the internal ALB from inside the VPC.
RECEIPT_PARSER_URL=

# Receipts are stored in a private S3 bucket (SSE + versioning) instead of on
# the container filesystem.
RECEIPTS_S3_BUCKET=
RECEIPTS_S3_PREFIX=
RECEIPTS_DIR=   # local scratch for uploads before S3 put

# --- Receipt parser (FastAPI on ECS Fargate) ---------------------------------
# In AWS we typically call a hosted LLM instead of shipping the Qwen weights
# in the image. Provide the key via SSM/Secrets Manager, not this file.
OPENAI_API_KEY=
QWEN_MODEL_PATH=

# --- Frontend (Vite build-time vars) -----------------------------------------
# Baked into the S3-hosted bundle at `npm run build` time. Must be an absolute
# URL because the static site and the API live on different origins.
VITE_BACKEND_URL=

# --- Container registry (ECR) ------------------------------------------------
ECR_REGISTRY=
ECR_BACKEND_REPO=
ECR_RECEIPT_PARSER_REPO=

# --- ECS ---------------------------------------------------------------------
ECS_CLUSTER=
ECS_BACKEND_SERVICE=
ECS_RECEIPT_PARSER_SERVICE=

# --- Frontend hosting (S3 / CloudFront) --------------------------------------
FRONTEND_S3_BUCKET=
CLOUDFRONT_DISTRIBUTION_ID=
