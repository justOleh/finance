# ------------------------------------------------------------------------------
# my-finance — LOCAL environment
# ------------------------------------------------------------------------------
# Used by `./deploy.sh --env local` (docker compose) and by developers running
# services directly on their machine. Everything points at localhost / on-disk
# paths — no cloud resources are required.
#
# Load in a shell with:  set -a; source envs/local.env; set +a
# Consumed by docker-compose.yml via `env_file:` or `${VAR}` substitution.
# ------------------------------------------------------------------------------

# --- Meta --------------------------------------------------------------------
PROJECT=my-finance
ENV_NAME=local

# --- Service ports (host) ----------------------------------------------------
BACKEND_PORT=8000
RECEIPT_PARSER_PORT=8001
FRONTEND_PORT=8501

# --- Public URLs (as seen from the host / browser) ---------------------------
BACKEND_URL=http://localhost:8000
RECEIPT_PARSER_URL_PUBLIC=http://localhost:8001
FRONTEND_URL=http://localhost:8501

# --- Backend (FastAPI) -------------------------------------------------------
# Consumed by backend/app/core/config.py
DATABASE_URL=sqlite:///./data/finance.db
# Inside the docker-compose network the parser is reachable by service name.
RECEIPT_PARSER_URL=http://receipt_parser:8001
RECEIPTS_DIR=./data/receipts

# --- Receipt parser (FastAPI + local Qwen model) -----------------------------
# Optional — leave blank to use the local Qwen3.5-2B model bundled in the image
# via the mounted volume (see docker-compose.yml).
OPENAI_API_KEY=
QWEN_MODEL_PATH=./app/data/models/Qwen3.5-2B

# --- Frontend (Vite build-time vars) -----------------------------------------
# VITE_* variables are baked into the bundle at build time. Empty string means
# "same-origin" — the nginx container proxies /expenses and /receipts to the
# backend, so no absolute URL is needed for the docker-compose stack.
VITE_BACKEND_URL=

# --- AWS (unused locally, kept for symmetry with aws.env) --------------------
AWS_REGION=
AWS_PROFILE=
